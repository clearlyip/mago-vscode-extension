{
  "name": "clearlyip/mago-lsp-test-project",
  "description": "Test PHP project for developing the Mago VS Code extension",
  "type": "project",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": ">=8.1"
  },
  "repositories": [
    {
      "type": "path",
      "url": "../"
    }
  ],
  "extra": {
    "enable-patching": true
  },
  "config": {
    "allow-plugins": {
      "clearlyip/mago-lsp": true
    }
  },
  "scripts": {
    "mago:lsp": "mago-lsp language-server",
    "mago": "mago"
  },
  "require-dev": {
    "carthage-software/mago": "^1.29.0",
    "clearlyip/mago-lsp": "dev-master"
  }
}
